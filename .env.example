# WhatsApp 千问机器人配置

# 阿里千问 API Key
QWEN_API_KEY=sk-**************************

# 阿里千问 API 端点
QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名称
QWEN_MODEL=
# 机器人名称
BOT_NAME=社群助手

# 是否启用打招呼功能
ENABLE_GREETING=true

# 打招呼消息
GREETING_MESSAGE=欢迎加入社群！我是 AI 助手，有什么问题可以随时问我~


# HTTP 代理（如果需要访问 WhatsApp）
HTTP_PROXY=

# 管理员电话号
MANAGER_PHONE=86***********

# 自测群聊ID
GROUP_ID=